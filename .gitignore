# ============================================================
# .gitignore — files Git should NOT track
# ============================================================

# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Node.js (if a build tool like Vite or Webpack is added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (if a bundler is added later)
dist/
build/

# Local environment / config overrides
.env
.env.local

# Log files
*.log
